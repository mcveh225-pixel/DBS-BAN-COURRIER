{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build-prod"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.ts" },
    { "source": "/ping", "destination": "/server.ts" },
    { "source": "/server-info", "destination": "/server.ts" },
    { "source": "/(.*)", "destination": "/build-prod/$1" }
  ]
}
